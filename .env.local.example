# =====================================================================
# CONFIGURACIÓN — copiá este archivo como .env.local y completá los valores
# =====================================================================

# URL pública de la app (Vercel)
NEXT_PUBLIC_BASE_URL=https://tu-dominio.vercel.app

# Teléfono WhatsApp visible al usuario (con código de país, sin signos)
NEXT_PUBLIC_WA_PHONE=5493515724733

# Precio del informe en ARS (visible en frontend)
NEXT_PUBLIC_INFORME_PRICE=9900
INFORME_PRICE_ARS=9900

# ----------------------------- SEO -----------------------------------
# Código de verificación de Google Search Console (sólo el valor del
# meta tag "google-site-verification", sin las comillas ni el tag).
GOOGLE_SITE_VERIFICATION=

# ----------------------------- SUPABASE ------------------------------
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxx.supabase.co
SUPABASE_URL=https://xxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --------------------------- GOOGLE SHEETS ---------------------------
# URL del Web App de Google Apps Script (doPost) que agrega una fila
# a tu hoja por cada pedido. Ver docs/GOOGLE-SHEETS.md.
GOOGLE_SHEETS_WEBHOOK_URL=

# --------------------------- MERCADOPAGO -----------------------------
# Credenciales: https://www.mercadopago.com.ar/developers/panel/app
# Para test usá TEST-..., para producción APP_USR-...
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxxxxxx-xxxxxxxxxxxxxxxx

# Secret para firmar webhooks (Developers → Webhooks → Tu URL → "Clave secreta")
# Si la dejás vacía, el webhook acepta cualquier llamada (útil sólo en dev).
MP_WEBHOOK_SECRET=

# Clave para proteger GET /api/health/mp (cualquier string).
# Si la dejás vacía, el endpoint queda público.
MP_HEALTH_KEY=

# ----------------------- DATOS BANCARIOS (TRANSFERENCIA) -------------
BANK_TITULAR=Gestoría Córdoba
BANK_NAME=Mercado Pago
BANK_ALIAS=GESTORIA.CBA.MP
BANK_CBU=0000003100012345678901
# URL de imagen QR estática (la de tu Mercado Pago / Modo). Opcional.
BANK_QR_URL=

# --------- NOTIFICACIÓN AUTOMÁTICA AL APROBARSE EL PAGO (webhook) -----
# Apenas MercadoPago confirma el pago, el servidor envía SÍ o SÍ el mensaje
# con TODOS los datos del pedido (servicio, nombre, patente, DNI, teléfono,
# email). No depende de que el cliente vuelva a la página.

# --- Opción A: WhatsApp automático (WhatsApp Cloud API de Meta) ---
# Requiere una app de Meta + número de WhatsApp Business API. Ver docs.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
# Tu WhatsApp (donde recibís el aviso con los datos), con código país, sin signos.
ADMIN_WHATSAPP_PHONE=5493515724733

# --- Opción B: Email automático (Resend) — la más fácil y 100% confiable ---
RESEND_API_KEY=
RESEND_FROM="Gestoría Córdoba <no-reply@gestoriacordoba.com>"
# Email tuyo (gestoría) donde recibís el aviso con TODOS los datos del pedido.
ADMIN_EMAIL=gestoriacordobaluci@gmail.com
