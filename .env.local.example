# =====================================================================
# CONFIGURACIÓN — copiá este archivo como .env.local y completá los valores
# =====================================================================

# URL pública de la app (Vercel)
NEXT_PUBLIC_BASE_URL=https://tu-dominio.vercel.app

# Precio del informe en ARS (visible en frontend)
NEXT_PUBLIC_INFORME_PRICE=6900
INFORME_PRICE_ARS=6900

# ----------------------------- SUPABASE ------------------------------
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxx.supabase.co
SUPABASE_URL=https://xxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --------------------------- MERCADOPAGO -----------------------------
# Tu credenciales: Developers → Credenciales
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxxxxxx-xxxxxxxxxxxxxxxx

# ----------------------- DATOS BANCARIOS (TRANSFERENCIA) -------------
BANK_TITULAR=Gestoría Córdoba
BANK_NAME=Banco Nación
BANK_ALIAS=GESTORIA.CBA.MP
BANK_CBU=0000003100012345678901

# ----------------------- NOTIFICACIONES (OPCIONAL) -------------------
